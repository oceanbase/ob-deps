+#pragma once
+
+#include <cstdint>
+
+#include "paimon/visibility.h"
+
+#define PAIMON_VERSION_MAJOR 0
+#define PAIMON_VERSION_MINOR 1
+#define PAIMON_VERSION_PATCH 2
+#define PAIMON_VERSION_STRING "0.1.2"
+#define PAIMON_VERSION_NUMBER                                            \
+    ((PAIMON_VERSION_MAJOR << 16) | (PAIMON_VERSION_MINOR << 8) | \
+     PAIMON_VERSION_PATCH)
+
+namespace paimon {
+
+/// Return the version string compiled into libpaimon.so (e.g. "0.1.2").
+/// Callers can compare this against PAIMON_VERSION_STRING from the header
+/// they were built with to detect header/library mismatches at load time.
+PAIMON_EXPORT const char* GetLibraryVersion();
+
+/// Return the packed version number compiled into libpaimon.so:
+/// (major << 16) | (minor << 8) | patch.
+PAIMON_EXPORT uint32_t GetLibraryVersionNumber();
+
+}  // namespace paimon
