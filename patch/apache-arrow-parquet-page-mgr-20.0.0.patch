+        PARQUET_THROW_NOT_OK(tmp_page_header_cache_buffer_->Resize(header_size, false));
+        uint8_t *tmp_buffer = tmp_page_header_cache_buffer_->mutable_data();
+        memcpy(tmp_buffer, retrieved_page_buffer->data(), header_size);
+      }
