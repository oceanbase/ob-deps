+std::shared_ptr<Page> SerializedPageReader::NextPageFromPageMgr() {
+  if (data_decryptor_ != nullptr) {
+    throw ParquetException("encryption not supported");
+  }
+
+  ThriftDeserializer deserializer(properties_);
+
+  while (current_read_offset_ < column_end_offset_) {
+    uint32_t header_size = 0;
+
+    int64_t current_page_offset = current_read_offset_;
+
+    if (last_read_page_offset_.has_value()) {
+      // release previous read page buffer first
+      if (OB_SUCCESS != properties_.get_page_mgr_release_page_func()(last_read_page_offset_.value())) {
+        throw ParquetException("PageMgr failed to release page");
+      }
+      last_read_page_offset_ = std::nullopt;
+    }
+
+    bool is_page_selected = false;
+    std::optional<int64_t> next_page_start_offset = std::nullopt;
+    if (OB_SUCCESS != properties_.get_page_mgr_check_page_selected_func()(current_page_offset, is_page_selected,
+                                                                          next_page_start_offset)) {
+      throw ParquetException("PageMgr failed to check page");
+    }
+    if (!is_page_selected) {
+      // skip current page
+      skip_page_callback_(current_page_offset);
+      if (next_page_start_offset.has_value()) {
+        current_read_offset_ = next_page_start_offset.value();
+      } else {
+        // already in the column end
+        current_read_offset_ = column_end_offset_;
+      }
+      continue;
+    }
+
+    std::shared_ptr<Buffer> retrieved_page_buffer; // retrieved page buffer from ParquetPageMgr
+    bool is_mem_cached = false;
+    bool is_decompressed = false;
+    if (OB_SUCCESS != properties_.get_page_mgr_read_page_func()(current_page_offset, retrieved_page_buffer,
+                                                                is_mem_cached,
+                                                                is_decompressed)) {
+      std::stringstream ss;
+      ss << "PageMgr failed to read page at offset " << current_page_offset;
+      throw ParquetException(ss.str());
+    }
+    if (is_decompressed && !is_mem_cached) {
+      throw ParquetException("unexpected error, if is_decompressed=true, must is_mem_cached=true");
+    }
+    last_read_page_offset_ = current_page_offset;
+
