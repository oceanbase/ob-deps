diff --git a/cmake_modules/FindArrowAlt.cmake b/cmake_modules/FindArrowAlt.cmake
index 8864163..9dce553 100644
--- a/cmake_modules/FindArrowAlt.cmake
+++ b/cmake_modules/FindArrowAlt.cmake
@@ -23,6 +23,58 @@ find_package(Parquet CONFIG QUIET ${_PAIMON_ARROW_FIND_ARGS})
 find_package(ArrowDataset CONFIG QUIET ${_PAIMON_ARROW_FIND_ARGS})
 find_package(ArrowAcero CONFIG QUIET ${_PAIMON_ARROW_FIND_ARGS})
 
+if(NOT TARGET Arrow::arrow_static AND NOT TARGET Arrow::arrow)
+    find_path(ARROW_INCLUDE_DIR
+              NAMES arrow/api.h
+              ${_PAIMON_ARROW_FIND_ARGS}
+              PATH_SUFFIXES include/apache-arrow include)
+    find_library(ARROW_LIBRARY
+                 NAMES arrow
+                 ${_PAIMON_ARROW_FIND_ARGS}
+                 PATH_SUFFIXES lib64 lib)
+    find_library(PARQUET_LIBRARY
+                 NAMES parquet
+                 ${_PAIMON_ARROW_FIND_ARGS}
+                 PATH_SUFFIXES lib64 lib)
+    find_library(ARROW_DATASET_LIBRARY
+                 NAMES arrow_dataset
+                 ${_PAIMON_ARROW_FIND_ARGS}
+                 PATH_SUFFIXES lib64 lib)
+    find_library(ARROW_ACERO_LIBRARY
+                 NAMES arrow_acero
+                 ${_PAIMON_ARROW_FIND_ARGS}
+                 PATH_SUFFIXES lib64 lib)
+
+    if(ARROW_INCLUDE_DIR
+       AND ARROW_LIBRARY
+       AND PARQUET_LIBRARY
+       AND ARROW_DATASET_LIBRARY
+       AND ARROW_ACERO_LIBRARY)
+        add_library(Arrow::arrow_static UNKNOWN IMPORTED)
+        set_target_properties(Arrow::arrow_static
+                              PROPERTIES IMPORTED_LOCATION "${ARROW_LIBRARY}"
+                                         INTERFACE_INCLUDE_DIRECTORIES
+                                         "${ARROW_INCLUDE_DIR}")
+        add_library(Parquet::parquet_static UNKNOWN IMPORTED)
+        set_target_properties(Parquet::parquet_static
+                              PROPERTIES IMPORTED_LOCATION "${PARQUET_LIBRARY}"
+                                         INTERFACE_INCLUDE_DIRECTORIES
+                                         "${ARROW_INCLUDE_DIR}")
+        add_library(ArrowDataset::arrow_dataset_static UNKNOWN IMPORTED)
+        set_target_properties(ArrowDataset::arrow_dataset_static
+                              PROPERTIES IMPORTED_LOCATION
+                                         "${ARROW_DATASET_LIBRARY}"
+                                         INTERFACE_INCLUDE_DIRECTORIES
+                                         "${ARROW_INCLUDE_DIR}")
+        add_library(ArrowAcero::arrow_acero_static UNKNOWN IMPORTED)
+        set_target_properties(ArrowAcero::arrow_acero_static
+                              PROPERTIES IMPORTED_LOCATION
+                                         "${ARROW_ACERO_LIBRARY}"
+                                         INTERFACE_INCLUDE_DIRECTORIES
+                                         "${ARROW_INCLUDE_DIR}")
+    endif()
+endif()
+
 function(_paimon_select_first_target OUT_VAR)
     foreach(_target IN LISTS ARGN)
         if(TARGET ${_target})
