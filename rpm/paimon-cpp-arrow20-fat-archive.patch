+#   http://www.apache.org/licenses/LICENSE-2.0
+#
+# Unless required by applicable law or agreed to in writing,
+# software distributed under the License is distributed on an
+# "AS IS" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY
+# KIND, either express or implied.  See the License for the
+# specific language governing permissions and limitations
+# under the License.
+
+# Extract object files from each archive in EXTRA_ARCHIVES and append them to
+# MAIN_ARCHIVE using ${CMAKE_AR} r. Intended for Unix static libraries only.
+
+if(NOT CMAKE_AR)
+    message(FATAL_ERROR "merge_static_archives: CMAKE_AR not set")
+endif()
+if(NOT MAIN_ARCHIVE)
+    message(FATAL_ERROR "merge_static_archives: MAIN_ARCHIVE not set")
+endif()
+if(NOT EXTRA_ARCHIVES)
+    message(FATAL_ERROR "merge_static_archives: EXTRA_ARCHIVES not set")
+endif()
+
+get_filename_component(_main_abs "${MAIN_ARCHIVE}" ABSOLUTE)
+if(NOT EXISTS "${_main_abs}")
+    message(FATAL_ERROR "merge_static_archives: MAIN_ARCHIVE does not exist: ${_main_abs}")
+endif()
+
+set(_tmp "${CMAKE_BINARY_DIR}/CMakeFiles/merge_static_archives.tmp")
+file(REMOVE_RECURSE "${_tmp}")
+file(MAKE_DIRECTORY "${_tmp}")
+
+set(_idx 0)
+foreach(_extra IN LISTS EXTRA_ARCHIVES)
+    if(NOT _extra)
+        continue()
+    endif()
+    get_filename_component(_extra_abs "${_extra}" ABSOLUTE)
+    if(NOT EXISTS "${_extra_abs}")
+        message(FATAL_ERROR "merge_static_archives: archive missing: ${_extra_abs}")
+    endif()
+    math(EXPR _idx "${_idx}+1")
+    set(_exdir "${_tmp}/lib_${_idx}")
+    file(MAKE_DIRECTORY "${_exdir}")
+    execute_process(COMMAND ${CMAKE_COMMAND} -E chdir "${_exdir}" ${CMAKE_AR} x
+                                                            "${_extra_abs}"
+                    RESULT_VARIABLE _rv)
+    if(NOT _rv EQUAL 0)
+        message(FATAL_ERROR "merge_static_archives: ar x failed for ${_extra_abs}")
+    endif()
+endforeach()
+
+file(GLOB_RECURSE _objs "${_tmp}/*.o")
+list(LENGTH _objs _n)
+if(_n EQUAL 0)
+    message(FATAL_ERROR "merge_static_archives: no .o members extracted (check archives)")
+endif()
+
+execute_process(COMMAND ${CMAKE_AR} r "${_main_abs}" ${_objs} RESULT_VARIABLE _rv)
+if(NOT _rv EQUAL 0)
+    message(FATAL_ERROR "merge_static_archives: ar r failed for ${_main_abs}")
+endif()
+
+if(CMAKE_RANLIB)
+    execute_process(COMMAND ${CMAKE_RANLIB} "${_main_abs}" RESULT_VARIABLE _rv)
+    if(NOT _rv EQUAL 0)
+        message(FATAL_ERROR "merge_static_archives: ranlib failed for ${_main_abs}")
+    endif()
+endif()
+
+file(REMOVE_RECURSE "${_tmp}")
